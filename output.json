wer":["8"]},{"slot_key":"blank_2","slot_type":"number","correct_answer":["4"]},{"slot_key":"blank_3","slot_type":"number","correct_answer":["6"]},{"slot_key":"blank_4","slot_type":"number","correct_answer":["2"]},{"slot_key":"blank_5","slot_type":"text","correct_answer":["苹果"]},{"slot_key":"blank_6","slot_type":"text","correct_answer":["梨"]}],"explanation":"数一数可知：苹果8个，香蕉4个，橙子6个，梨2个。苹果最多，梨最少。"}]}]