# Runtime
NODE_ENV=production
PORT=3000

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=kids_quiz
DB_PASSWORD=replace-with-strong-password
DB_NAME=kids_quiz
DATABASE_URL="mysql://kids_quiz:replace-with-strong-password@127.0.0.1:3306/kids_quiz"

# First admin account used by setup scripts
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-before-first-run

# Auth
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRES_IN=7d
STUDENT_JWT_EXPIRES_IN=30d

# Uploads
UPLOAD_DIR=/var/lib/kids-quiz/uploads
PUBLIC_API_BASE_URL=https://quiz.example.com/api
